#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ELPA_DIR="$DOTFILES_DIR/emacs.d/elpa"
LISP_DIR="$DOTFILES_DIR/emacs.d/lisp"
INIT_EL="$DOTFILES_DIR/emacs.d/init.el"

# Vendored lisp/ packages and their upstream repos
declare -A LISP_REPOS=(
  [breadcrumb]="https://github.com/joaotavora/breadcrumb.git"
  [claude-code]="https://github.com/stevemolitor/claude-code.el.git"
  [combobulate]="https://github.com/mickeynp/combobulate.git"
  [cpp-func-impl]="https://github.com/dheerajshenoy/cpp-func-impl.git"
  [dogears.el]="https://github.com/alphapapa/dogears.el.git"
  [emacs-corfu-terminal]="https://codeberg.org/akib/emacs-corfu-terminal.git"
  [emacs-flymake-popon]="https://codeberg.org/akib/emacs-flymake-popon.git"
  [emacs-popon]="https://codeberg.org/akib/emacs-popon.git"
  [gptel]="https://github.com/karthink/gptel.git"
  [hydra-posframe]="https://github.com/Ladicle/hydra-posframe.git"
  [inheritenv]="https://github.com/purcell/inheritenv.git"
  [prism.el]="https://github.com/alphapapa/prism.el.git"
  [treesit-fold]="https://github.com/emacs-tree-sitter/treesit-fold.git"
)

# Update vendored lisp/ packages
echo "=== Updating lisp/ packages ==="
for pkg in "${!LISP_REPOS[@]}"; do
  dir="$LISP_DIR/$pkg"
  url="${LISP_REPOS[$pkg]}"
  if [ -d "$dir/.git" ]; then
    echo "Pulling $pkg..."
    git -C "$dir" pull --ff-only 2>&1 || echo "  WARNING: pull failed for $pkg"
  else
    echo "Cloning $pkg..."
    rm -rf "$dir"
    if ! git clone --depth 1 "$url" "$dir" 2>&1; then
      echo "  WARNING: Failed to clone $pkg"
    fi
  fi
done

# Update vendored tree-sitter grammar sources
# Grammar list is extracted from init.el via emacs to avoid duplication
TS_SRC_DIR="$DOTFILES_DIR/emacs.d/tree-sitter-src"

echo ""
echo "=== Updating tree-sitter grammar sources ==="
mkdir -p "$TS_SRC_DIR"

# Extract grammar list from mp-treesit-grammar-sources in init.el
# Output format: lang\turl\trev\tsrcdir (one per line)
TS_GRAMMAR_LIST=$(emacs --batch --load "$INIT_EL" --eval "
(dolist (g mp-treesit-grammar-sources)
  (princ (format \"%s\t%s\t%s\t%s\n\"
                 (car g) (nth 1 g) (or (nth 2 g) \"\")
                 (or (nth 3 g) \"src\"))))
" 2>/dev/null)

while IFS=$'\t' read -r lang url rev srcdir; do
  [ -z "$lang" ] && continue
  srcdir="${srcdir:-src}"
  dir="$TS_SRC_DIR/$lang"
  srcparent=$(dirname "$srcdir")
  if [ -d "$dir/.git" ]; then
    echo "Pulling $lang..."
    git -C "$dir" pull --ff-only 2>&1 || echo "  WARNING: pull failed for $lang"
  else
    echo "Cloning $lang..."
    rm -rf "$dir"
    git clone --depth 1 --filter=blob:none --no-checkout --branch "$rev" "$url" "$dir" 2>/dev/null
    if [ "$srcparent" != "." ]; then
      git -C "$dir" sparse-checkout set "$srcparent/src" 2>/dev/null
    else
      git -C "$dir" sparse-checkout set src 2>/dev/null
    fi
    git -C "$dir" checkout 2>/dev/null || echo "  WARNING: Failed to clone $lang"
  fi
done <<< "$TS_GRAMMAR_LIST"

# Update ELPA packages
echo ""
echo "=== Updating ELPA packages ==="
emacs --batch \
  --eval "(setq package-user-dir \"$ELPA_DIR\")" \
  --eval "(setq package-native-compile t)" \
  --eval "(require 'package)" \
  --eval "(add-to-list 'package-archives '(\"melpa\" . \"https://melpa.org/packages/\") t)" \
  --eval "(setq package-archive-priorities
            '((\"gnu\" . 10) (\"nongnu\" . 5) (\"melpa\" . 0)))" \
  --eval "(package-initialize)" \
  --eval "(package-refresh-contents)" \
  --eval "(load \"$INIT_EL\" nil t)" \
  --eval "(package-install-selected-packages t)"

echo ""
echo "Done. Review changes with: cd $DOTFILES_DIR && git status"
echo "Then commit with: git add emacs.d/ && git commit -m 'Update vendored packages'"
